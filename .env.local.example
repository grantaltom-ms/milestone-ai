# Copy this file to .env.local and fill in real values before running locally.
# All variables are required unless marked optional.

# Admin auth
ADMIN_PASSWORD=your_admin_password

# Supabase — main project
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase — expenses-v2 project (tenant reply logs)
EXPENSES_SUPABASE_URL=https://yyyy.supabase.co
EXPENSES_SUPABASE_SERVICE_ROLE_KEY=your_expenses_service_role_key

# Gmail (work-order email polling)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Slack
SLACK_BOT_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# Cron route protection
CRON_SECRET=your_random_cron_secret

# milestone-pov service
MILESTONE_POV_API_URL=https://
POV_API_SECRET=
